PORT=3000

OPENAI_API_KEY=replace_with_your_real_openai_api_key
OPENAI_MODEL=gpt-5-mini

RESPONDIO_API_TOKEN=replace_with_your_real_respondio_developer_api_token
RESPONDIO_API_BASE_URL=https://api.respond.io/v2

# Use the signing key shown/generated by Respond.io for this webhook.
RESPONDIO_WEBHOOK_SECRET=replace_with_the_respondio_webhook_signing_key

# Used only for the protected /test-ai route.
GATEWAY_SECRET=replace_with_a_different_long_random_secret

MAX_HISTORY_MESSAGES=16
